# Lattice iCEstick (iCE40HX1K-TQ144) minimal constraints.
# Only the clock and the five on-board LEDs are pinned; the core's real
# I/O never leaves the chip in this evaluation build.

set_io clk 21        # 12 MHz on-board oscillator

set_io led[0] 99     # D1 (red)
set_io led[1] 98     # D2 (red)
set_io led[2] 97     # D3 (red)
set_io led[3] 96     # D4 (red)
set_io led[4] 95     # D5 (green, center)

# --- Decided sensor/telemetry pin map (Jenga bench integration) ---
# Uncomment each line when the matching RTL port lands (roadmap R1/R2).
# Maps the signal names from docs/a·rchitecture/schematic.png to real
# TQ144 pins. nextpnr errors on constraints for ports that don't exist
# in the top module, so these stay commented until then.
#
# UART telemetry: NO external wiring — the on-board FT2232H channel B
# is hard-wired to these pins and shows up on the laptop as the second
# ttyUSB device of the iCEstick:
set_io uart_txd 8     # FPGA -> FTDI -> laptop (schematic UART_TX), live
# set_io uart_rxd 9   # laptop -> FTDI -> FPGA (schematic UART_RX), future
#
# I2C sensor bus + payload control on PMOD J2 (open-drain SDA/SCL,
# external 4.7k pull-ups to the sensor rail; grounds must be common):
# set_io i2c_sda 78     # J2 pin 1 (schematic I2C_SDA)
# set_io i2c_scl 79     # J2 pin 2 (schematic I2C_SCL)
# set_io payload_en 80  # J2 pin 3 -> IRLZ44N gate (schematic PAYLOAD_EN)
# set_io imu_int 81     # J2 pin 4 <- MPU6050 INT (schematic IMU_INT)
# spare J2: 87 | 88 | 90 | 91
#
# More I/O if needed:
# Header J1: 112 | 113 | 114 | 115 | 116 | 117 | 118 | 119
# Header J3: 62 | 61 | 60 | 56 | 48 | 47 | 45 | 44
# IrDA (avoid, used by transceiver): 106 (RXD) | 105 (TXD) | 107 (SD)
